events{}
http{ upstream backend_servers {
	server website1:80;
	server website2:80;

}
server{     
	server_name amanpractice.work.gd www.amanpractice.work.gd;
    listen 80;

     location /.well-known/acme-challenge/ {

            root /var/www/certbot;
        }
    location / {
    proxy_pass http://backend_servers;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;



}

}




}
